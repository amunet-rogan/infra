# Copy this file to .env and fill in the real token.
# .env is gitignored and excluded from sync-to-amunet.sh — it stays
# only on Amunet, never in git, never in the sync.
#
# Token creation:
#   1. https://github.com/settings/tokens/new
#   2. Name: "amunet-rogan self-hosted runner"
#   3. Expiration: 1 year (or longer — re-setting it is a small chore)
#   4. Scope: admin:org (just that checkbox)
#   5. Generate → copy value into the line below
#
# The token is used only to fetch short-lived runner registration tokens
# at container startup. It is not exposed to workflow jobs.

ACCESS_TOKEN=ghp_PUT_YOUR_PAT_HERE
